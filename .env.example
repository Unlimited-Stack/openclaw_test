# ── 数据库 ──
DATABASE_URL=postgresql://cosoul:cosoul@localhost:5432/cosoul_agent

# ── JWT 签名密钥 ──
JWT_SECRET=change-me-in-production

# ── Bridge 服务端口 ──
BRIDGE_PORT=4060

# ── 日志级别 ──
LOG_LEVEL=info

# ── 以下供客户端测试脚本使用 ──
# Bridge WebSocket 地址
BRIDGE_URL=ws://localhost:4060

# 通过 /api/openclaw/keys POST 接口获取的 rawKey
API_KEY=your_api_key_here
